---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../lib/i18n';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/blog');
}

const post = await getEntry('blog', slug);

if (!post) {
  return Astro.redirect('/blog');
}

const { Content } = await render(post);
---

<BaseLayout locale={post.data.lang as 'es' | 'en'} title={`${post.data.title} | Blog | Juanma MC`}>
  <main class="pt-24 pb-24">
    <div class="section-container">
      <article class="max-w-3xl mx-auto">
        <div class="mb-8">
          <a
            href="/blog"
            class="text-sm text-primary hover:underline mb-4 inline-block"
          >
            ← Volver al blog
          </a>

          <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>

          <div class="flex items-center gap-4 text-sm text-muted-foreground">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <span>{post.data.readTime} {t('es', 'blog.minRead')}</span>
          </div>

          <div class="flex flex-wrap gap-1.5 mt-4">
            {post.data.tags.map((tag: string) => (
              <span class="inline-flex items-center rounded-full border border-border bg-muted px-2.5 py-0.5 text-xs font-medium text-muted-foreground">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <div class="prose prose-neutral dark:prose-invert max-w-none">
          <Content />
        </div>
      </article>
    </div>
  </main>
</BaseLayout>

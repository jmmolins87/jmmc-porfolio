---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { db } from '@/db';
import { posts } from '@/db/schema';
import { desc } from 'drizzle-orm';

const lang = (Astro.url.searchParams.get('lang') as 'es' | 'en') ?? 'es';

const allPosts = await db
  .select()
  .from(posts)
  .orderBy(desc(posts.publishedAt));
---

<DashboardLayout title="Blog">
  <div class="section-container">
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-4">
        <h1 class="section-title">Blog Posts</h1>
        <div class="flex gap-2 border-b border-border">
          <a
            href="/dashboard/blog?lang=es"
            class:list={[
              'px-4 py-2 text-sm font-medium border-b-2 transition-colors',
              lang === 'es' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'
            ]}
          >
            Español
          </a>
          <a
            href="/dashboard/blog?lang=en"
            class:list={[
              'px-4 py-2 text-sm font-medium border-b-2 transition-colors',
              lang === 'en' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'
            ]}
          >
            English
          </a>
        </div>
      </div>
      <a
        href="/dashboard/blog/new"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-primary text-primary-foreground font-medium hover:opacity-90 transition-opacity"
      >
        + Nuevo post
      </a>
    </div>

    <div id="post-list" data-posts={JSON.stringify(allPosts)} data-lang={lang}>
      <p class="text-muted-foreground text-center py-12">Cargando...</p>
    </div>
  </div>

  <script>
    import React from 'react';
    import { createRoot } from 'react-dom/client';
    import PostList from '@/components/dashboard/PostList';

    const container = document.getElementById('post-list');
    const posts = JSON.parse(container?.dataset.posts ?? '[]');
    const lang = (container?.dataset.lang ?? 'es') as 'es' | 'en';

    let currentPosts = posts;

    function render() {
      if (!container) return;
      container.innerHTML = '';
      const root = createRoot(container);
      root.render(
        React.createElement(PostList, {
          posts: currentPosts,
          lang,
          onDelete: (id: string) => {
            currentPosts = currentPosts.filter((p: { id: string }) => p.id !== id);
            render();
          },
        })
      );
    }

    render();
  </script>
</DashboardLayout>
